{
  "name": "Purchase",
  "type": "object",
  "properties": {
    "stripePaymentIntentId": {
      "type": "string",
      "description": "Stripe Payment Intent ID"
    },
    "amount": {
      "type": "number",
      "description": "Amount paid in cents (2500 for $25)"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "completed",
        "failed"
      ],
      "description": "Payment status"
    },
    "userEmail": {
      "type": "string",
      "description": "Email of the user who made the purchase"
    }
  },
  "required": [
    "stripePaymentIntentId",
    "amount",
    "status",
    "userEmail"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "$or": [
          {
            "role": "admin"
          },
          {
            "email": "record.userEmail"
          }
        ]
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}