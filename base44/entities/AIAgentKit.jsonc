{
  "name": "AIAgentKit",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the AI agent/API"
    },
    "description": {
      "type": "string",
      "description": "Description of what the API does"
    },
    "url": {
      "type": "string",
      "description": "Link to the API"
    },
    "category": {
      "type": "string",
      "description": "Category tag for filtering"
    },
    "detailed_info": {
      "type": "string",
      "description": "AI-generated detailed information about the resource"
    }
  },
  "required": [
    "name",
    "description",
    "url"
  ]
}